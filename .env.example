# Django (auto-copied to .env on first start.bat run)
SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=True
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# OpenWeatherMap — https://openweathermap.org/api (optional; without key, live weather uses Open-Meteo)
OPENWEATHER_API_KEY=
OPENWEATHER_TIMEOUT=8

# Agmarknet / data.gov.in mandi prices — https://data.gov.in/ (register for free API key)
AGMARKNET_API_KEY=
# Alias also supported:
DATA_GOV_API_KEY=
AGMARKNET_TIMEOUT=12

# Google Gemini (AI chatbot) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI fallback (optional)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
CHAT_API_TIMEOUT=45
CHAT_RATE_LIMIT_PER_HOUR=30

# Twilio SMS (optional — future alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional local TensorFlow disease model path
DISEASE_MODEL_PATH=agro/ml/models/plant_disease_mobilenet.keras
